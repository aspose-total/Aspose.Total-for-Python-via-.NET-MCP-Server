# Aspose CAD MCP Server — Environment Variables
# Cross-platform: Windows, Linux, macOS

# Files folder: CAD files (.dwg, .dxf, .ifc, .dgn, etc.) placed here;
# converted output files (PDF, PNG, etc.) written here too
ASPOSE_FILES_PATH=/path/to/your/files/folder

# Aspose license file path (optional — evaluation mode without it)
ASPOSE_LICENSE_FILE=/path/to/your/Aspose.Total.lic

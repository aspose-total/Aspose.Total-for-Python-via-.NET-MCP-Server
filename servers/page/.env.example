# Aspose Page MCP Server — Environment Variables
# PLATFORM: Windows only (x86/x64)

# Files folder: .xps, .oxps, .ps, .eps, .ai files placed here; outputs written here
ASPOSE_FILES_PATH=C:\path\to\your\files\folder

# Aspose license file path (optional — evaluation mode without it)
ASPOSE_LICENSE_FILE=C:\path\to\your\Aspose.Total.lic

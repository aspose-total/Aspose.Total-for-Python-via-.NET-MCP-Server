# Aspose PSD MCP Server — Environment Variables
# Cross-platform: Windows, Linux, macOS

# Input folder: .psd, .psb, and .ai files placed here
ASPOSE_INPUT_DIR=/path/to/your/input/folder

# Output folder: exported files (PNG, JPEG, PDF, etc.) written here
ASPOSE_OUTPUT_DIR=/path/to/your/output/folder

# Aspose license file path (optional — evaluation mode without it)
ASPOSE_LICENSE_PATH=/path/to/your/Aspose.Total.lic

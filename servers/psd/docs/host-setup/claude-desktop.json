{
  "mcpServers": {
    "aspose-psd": {
      "command": "/absolute/path/to/servers/psd/.venv/bin/python",
      "args": ["servers/psd/server.py"],
      "cwd": "/absolute/path/to/mcp-aspose-python",
      "env": {
        "ASPOSE_INPUT_DIR": "/path/to/your/input/folder",
        "ASPOSE_OUTPUT_DIR": "/path/to/your/output/folder",
        "ASPOSE_LICENSE_PATH": "/path/to/your/Aspose.Total.lic"
      }
    }
  }
}

# Aspose TeX MCP Server — Environment Variables
# PLATFORM: Windows only (x86/x64)

# Input folder: .tex and .ltx files are placed here
ASPOSE_INPUT_DIR=C:\path\to\your\input\folder

# Output folder: converted files are written here
ASPOSE_OUTPUT_DIR=C:\path\to\your\output\folder

# Aspose license file path (optional — evaluation mode without it)
ASPOSE_LICENSE_PATH=C:\path\to\your\Aspose.Total.lic

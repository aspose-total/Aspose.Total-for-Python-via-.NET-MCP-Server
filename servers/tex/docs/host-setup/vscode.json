{
  "servers": {
    "aspose-tex": {
      "type": "stdio",
      "command": "${workspaceFolder}\\servers\\tex\\.venv\\Scripts\\python.exe",
      "args": ["servers\\tex\\server.py"],
      "env": {
        "ASPOSE_INPUT_DIR": "${workspaceFolder}\\input",
        "ASPOSE_OUTPUT_DIR": "${workspaceFolder}\\output"
      }
    }
  }
}
